{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "rollNumber": { "type": "string", "description": "Student roll number" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A collection of questions with a deadline",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "deadline": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "description": "Teacher UID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "questions", "deadline", "createdBy", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "Assessment question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["mcq", "short_answer", "python_program"] },
        "question": { "type": "string" },
        "marks": { "type": "number" }
      },
      "required": ["id", "type", "question"]
    },
    "AssignmentSubmission": {
      "title": "AssignmentSubmission",
      "description": "Student submission for an entire assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignment_id": { "type": "string" },
        "student_id": { "type": "string" },
        "student_name": { "type": "string" },
        "answers": { "type": "object", "description": "Map of question_id to answer details" },
        "total_marks_awarded": { "type": "number" },
        "total_possible_marks": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "assignment_id", "student_id", "student_name", "answers", "total_marks_awarded", "total_possible_marks", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments created by teachers"
    },
    "/submissions/{submissionId}": {
      "schema": "AssignmentSubmission",
      "description": "Student submissions for assignments"
    }
  }
}
