rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, 'teacher' or 'student')
    //   - rollNumber: string (required for students)
    //
    // Collection: assignments
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - description: string
    //   - questions: array (required)
    //   - deadline: string (required, ISO 8601)
    //   - createdBy: string (required)
    //   - createdAt: string (required)
    //
    // Collection: submissions
    // Fields:
    //   - assignment_id: string (required)
    //   - student_id: string (required)
    //   - student_name: string (required)
    //   - answers: map (required)
    //   - total_marks_awarded: number (required)
    //   - total_possible_marks: number (required)
    //   - timestamp: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isAuthenticated() && (
        (request.auth.token.email == "yuvaakash16@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')
      );
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
                    request.resource.data.role in ['teacher', 'student'] &&
                    request.resource.data.keys().hasAll(['uid', 'email', 'name', 'role']) &&
                    (request.resource.data.role == 'teacher' || request.resource.data.rollNumber is string);
      allow update: if isOwner(userId) && 
                    request.resource.data.role == resource.data.role; // Role cannot be changed
    }

    // Assignments Collection
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // Submissions Collection
    match /submissions/{submissionId} {
      allow read: if isTeacher() || (isAuthenticated() && resource.data.student_id == request.auth.uid);
      allow create: if isStudent() && request.resource.data.student_id == request.auth.uid;
      allow update: if false; // Submissions are immutable
      allow delete: if isTeacher();
    }
  }
}
